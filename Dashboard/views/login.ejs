<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= title %></title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.1.3/dist/css/bootstrap.min.css" rel="stylesheet">
    <style>
        body {
            background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
            min-height: 100vh;
            display: flex;
            align-items: center;
            justify-content: center;
        }
        .login-card {
            background: white;
            border-radius: 15px;
            box-shadow: 0 10px 30px rgba(0,0,0,0.2);
            padding: 3rem;
            text-align: center;
            max-width: 400px;
            width: 100%;
        }
        .btn-discord {
            background: #5865F2;
            border: none;
            padding: 15px 30px;
            font-size: 18px;
            border-radius: 25px;
            width: 100%;
            transition: all 0.3s;
        }
        .btn-discord:hover {
            background: #4752c4;
            transform: translateY(-2px);
            box-shadow: 0 5px 15px rgba(88, 101, 242, 0.4);
        }
    </style>
</head>
<body>
    <div class="login-card">
        <i class="fab fa-discord fa-4x text-primary mb-4"></i>
        <h2 class="mb-3">Login Required</h2>
        <p class="text-muted mb-4">Please login with your Discord account to access the bot dashboard.</p>

        <a href="/auth/discord" class="btn btn-discord">
            <i class="fab fa-discord me-2"></i>
            Login with Discord
        </a>

        <p class="mt-3 small text-muted">
            You need to have server management permissions in at least one server.
        </p>
    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.1.3/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>