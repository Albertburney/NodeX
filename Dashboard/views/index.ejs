<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= title %></title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.1.3/dist/css/bootstrap.min.css" rel="stylesheet">
    <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css" rel="stylesheet">
    <style>
        body {
            background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
            min-height: 100vh;
            display: flex;
            align-items: center;
            justify-content: center;
        }
        .welcome-card {
            background: white;
            border-radius: 15px;
            box-shadow: 0 10px 30px rgba(0,0,0,0.2);
            padding: 3rem;
            text-align: center;
            max-width: 600px;
            width: 100%;
        }
        .btn-discord {
            background: #5865F2;
            border: none;
            padding: 12px 30px;
            font-size: 18px;
            border-radius: 25px;
            transition: all 0.3s;
        }
        .btn-discord:hover {
            background: #4752c4;
            transform: translateY(-2px);
            box-shadow: 0 5px 15px rgba(88, 101, 242, 0.4);
        }
        .features {
            margin-top: 2rem;
        }
        .feature-item {
            background: #f8f9fa;
            padding: 1rem;
            border-radius: 10px;
            margin: 0.5rem 0;
        }
    </style>
</head>
<body>
    <div class="welcome-card">
        <i class="fas fa-robot fa-4x text-primary mb-4"></i>
        <h1 class="display-4 mb-3">Relay Bot Dashboard</h1>
        <p class="lead mb-4">Manage your Discord bot settings, view statistics, and control your servers from one place.</p>

        <% if (!user) { %>
            <a href="/login" class="btn btn-discord btn-lg">
                <i class="fab fa-discord me-2"></i>
                Login with Discord
            </a>

            <div class="features mt-5">
                <h5 class="mb-3">Features:</h5>
                <div class="row">
                    <div class="col-md-6">
                        <div class="feature-item">
                            <i class="fas fa-cog text-primary me-2"></i>
                            Server Settings
                        </div>
                    </div>
                    <div class="col-md-6">
                        <div class="feature-item">
                            <i class="fas fa-shield-alt text-success me-2"></i>
                            Auto Moderation
                        </div>
                    </div>
                    <div class="col-md-6">
                        <div class="feature-item">
                            <i class="fas fa-chart-bar text-info me-2"></i>
                            Statistics & Logs
                        </div>
                    </div>
                    <div class="col-md-6">
                        <div class="feature-item">
                            <i class="fas fa-music text-warning me-2"></i>
                            Music Controls
                        </div>
                    </div>
                </div>
            </div>
        <% } else { %>
            <div class="alert alert-success">
                <i class="fas fa-check-circle me-2"></i>
                Successfully logged in as <%= user.username %>
            </div>
            <a href="/dashboard" class="btn btn-primary btn-lg">
                <i class="fas fa-tachometer-alt me-2"></i>
                Go to Dashboard
            </a>
        <% } %>
    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.1.3/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>